{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$PLUGIN_ROOT/scripts/setup.sh\"",
            "timeout": 10,
            "statusMessage": "Preparing ADtention"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$PLUGIN_ROOT/scripts/on-prompt.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
